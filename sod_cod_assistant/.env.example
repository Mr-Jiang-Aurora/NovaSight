# ═══════════════════════════════════════════════════════════════════════════
# SOD/COD 科研助手 — 环境变量配置模板
# 使用方法：复制本文件，重命名为 .env，填入真实值后启动后端
# ═══════════════════════════════════════════════════════════════════════════


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【必填】AI 提供商配置（选择下面三种方式之一）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 当前激活的 AI 提供商：claude 或 openai
# 可在前端界面顶部状态栏实时切换（本次运行有效），永久修改改这里
ACTIVE_AI_PROVIDER=openai


# ─────────────────────────────────────────────────────────────────────────
# 方式 A：使用 URL 中转商（推荐，可访问 Claude + GPT 全系列）
#
#   本系统已测试的中转商：apiport.cc（支持 Claude Sonnet、GPT-5.4 等）
#   中转商通常兼容 OpenAI SDK 格式，用 OPENAI_* 系列变量即可
#
#   ⚠️ OPENAI_BASE_URL 必须以 /v1 结尾，否则请求会被拒绝
#   ⚠️ 如遇网络错误，可尝试将 apiport.cc 改为 apiport.cc.cd（或反之）
# ─────────────────────────────────────────────────────────────────────────

# Claude 通过中转商（ANTHROPIC_BASE_URL 不加 /v1）
ANTHROPIC_API_KEY=sk-your_relay_key_here
ANTHROPIC_BASE_URL=https://apiport.cc
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI / GPT 通过中转商（必须加 /v1）
OPENAI_API_KEY=sk-your_relay_key_here
OPENAI_BASE_URL=https://apiport.cc/v1
OPENAI_MODEL=gpt-5.4


# ─────────────────────────────────────────────────────────────────────────
# 方式 B：直连 Anthropic 官方 Claude API
#
#   申请地址：https://console.anthropic.com/
#   Key 格式：sk-ant-api03-xxxx
#   ANTHROPIC_BASE_URL 留空 = 使用官方地址（api.anthropic.com）
# ─────────────────────────────────────────────────────────────────────────

# ACTIVE_AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-api03-your_real_claude_key_here
# ANTHROPIC_BASE_URL=                 # 留空，使用 api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6   # 或 claude-opus-4-6（更贵但更强）


# ─────────────────────────────────────────────────────────────────────────
# 方式 C：直连 OpenAI 官方 API
#
#   申请地址：https://platform.openai.com/api-keys
#   Key 格式：sk-proj-xxxx
#   OPENAI_BASE_URL 留空 = 使用官方地址（api.openai.com/v1）
# ─────────────────────────────────────────────────────────────────────────

# ACTIVE_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-your_real_openai_key_here
# OPENAI_BASE_URL=                    # 留空，使用 api.openai.com/v1
# OPENAI_MODEL=gpt-4o                 # 或 gpt-4-turbo、o1 等


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 学术搜索 API 配置（Agent1 SOTA 调研使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Semantic Scholar API Key（可选，不填以无 Key 降级运行，限速 100 req/5min）
# 申请地址：https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex API Key（2026年2月起必须填写）
# 申请地址：https://openalex.org/settings/api
OPENALEX_API_KEY=your_openalex_api_key_here
OPENALEX_EMAIL=your_email@example.com

# Unpaywall（PDF 开放获取，填邮箱即可，不会收到邮件）
UNPAYWALL_EMAIL=your_email@example.com

# CORE API Key（可选，PDF 获取的终极兜底源）
# 申请地址（免费）：https://core.ac.uk/services/api#form
CORE_API_KEY=your_core_api_key_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 搜索行为配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 每次请求之间的延迟（秒），防止 API 限速
SEARCH_REQUEST_DELAY=1.0
# 每个来源最多返回的论文数
SEARCH_MAX_RESULTS_PER_SOURCE=50
# 搜索超时（秒）
SEARCH_TIMEOUT=30
# 只保留该年份及以后的论文（推荐 2024，涵盖近两年最新成果）
SEARCH_MIN_YEAR=2024
# 最低 Venue Tier（1=只要CCF-A/Q1；2=同时包含CCF-B/Q2）
VENUE_MIN_TIER=1


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PDF 获取配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

FETCH_MAX_CONCURRENT=5
FETCH_TIMEOUT=15
PDF_DOWNLOAD_DIR=cache/pdfs


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 缓存与输出目录
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

CACHE_DIR=cache/sota_cache
PARSE_OUTPUT_DIR=cache/sota_cache


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Agent3 代码分析配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GitHub Personal Access Token（可选，不填也能用，但限制 60 次/小时）
# 获取：https://github.com/settings/tokens → 勾选 repo（或 public_repo）
GITHUB_TOKEN=
AGENT3_MAX_CONCURRENT=3


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Agent4 视觉分析配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 视觉分析专用模型（可选）
# 留空 = 使用上面配置的 OPENAI_MODEL 或 ANTHROPIC_MODEL
# 若中转商支持，填 claude-opus-4-6 可显著提升架构图解析质量
# 注意：Opus 费率约为 Sonnet 的 5 倍
VISION_MODEL=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PDF 表格解析配置（Phase 3 VLM 兜底）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 表格解析并发数（推荐 3，内存较小的机器可调低）
PARSE_MAX_CONCURRENT=3
# 是否启用 VLM 兜底解析（true/false）
# true = 当 PyMuPDF 无法提取表格时，调用多模态模型识图解析，会消耗 API 额度
ENABLE_VLM_FALLBACK=true


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：你的研究方案描述（Agent2 会据此生成针对性建议）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 示例："基于Mamba骨干网络的COD方法，引入判别器驱动的自适应路由模块"
USER_METHOD_DESC=
